<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve existing files and directories as-is (assets, vendor, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route all other requests through the local preview router
    RewriteRule ^ index.php [L]
</IfModule>
